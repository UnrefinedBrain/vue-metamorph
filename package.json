{
  "name": "vue-metamorph",
  "version": "3.3.7",
  "description": "Codemod framework for Vue files",
  "keywords": [
    "codemod",
    "vue",
    "ast"
  ],
  "bin": {
    "vue-metamorph": "scripts/scaffold.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/UnrefinedBrain/vue-metamorph.git"
  },
  "bugs": "https://github.com/UnrefinedBrain/vue-metamorph/issues",
  "author": {
    "name": "UnrefinedBrain",
    "email": "github@unrefinedbrain.dev",
    "url": "https://github.com/UnrefinedBrain"
  },
  "license": "MIT",
  "files": [
    "dist",
    "scripts/scaffold.js",
    "template"
  ],
  "type": "module",
  "main": "dist/main.mjs",
  "types": "dist/vue-metamorph.d.ts",
  "typings": "dist/vue-metamorph.d.ts",
  "exports": {
    ".": {
      "types": "./dist/vue-metamorph.d.ts",
      "import": "./dist/main.mjs"
    }
  },
  "scripts": {
    "build": "scripts/build",
    "lint": "oxlint src docs/.vitepress",
    "fmt": "oxfmt --write src docs/.vitepress",
    "fmt:check": "oxfmt --check src docs/.vitepress",
    "test": "vitest",
    "docs:dev": "pnpm build && vitepress dev docs",
    "docs:build": "pnpm build && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "pnpm": {
    "overrides": {
      "vue": "^3.5.18"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@microsoft/api-documenter": "^7.30.5",
    "@microsoft/api-extractor": "^7.58.7",
    "@shikijs/vitepress-twoslash": "^2.5.0",
    "@types/cli-progress": "^3.11.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.8.0",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.6",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitepress": "1.6.4",
    "vitest": "^4.1.6",
    "vue-metamorph": "link:"
  },
  "dependencies": {
    "@babel/parser": "8.0.0-alpha.12",
    "ast-types-x": "1.18.0",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "lodash-es": "^4.18.1",
    "magic-string": "^0.30.21",
    "node-html-parser": "^7.1.0",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.14",
    "postcss-less": "^6.0.0",
    "postcss-sass": "^0.5.0",
    "postcss-scss": "^4.0.9",
    "postcss-styl": "^0.12.3",
    "recast-x": "1.0.5",
    "table": "^6.9.0",
    "tinyglobby": "^0.2.16",
    "vue-eslint-parser": "^10.4.0"
  }
}
